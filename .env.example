# PostgreSQL bağlantı URL'i (Supabase veya yerel PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/geo_platform"

# Anthropic Claude API anahtarı
ANTHROPIC_API_KEY="sk-ant-..."

# NextAuth
NEXTAUTH_SECRET="supersecretkey-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (opsiyonel)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend e-posta servisi
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@geo-platform.com"

# Inngest background jobs
INNGEST_EVENT_KEY="..."
INNGEST_SIGNING_KEY="..."

# Uygulama URL'i (webhook ve snippet URL'leri için)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# /admin paneline erişim — bu e-posta ile giriş yapan kullanıcı admin sayılır
# Production'da (Vercel) ayarlanmazsa /admin "Yetkisiz erişim" döner
ADMIN_EMAIL="ozgasl@gmail.com"
